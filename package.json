{
  "name": "voicebox",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "app",
    "tauri",
    "web",
    "landing"
  ],
  "scripts": {
    "dev": "node scripts/setup-dev-sidecar.js && cd tauri && npm run tauri dev",
    "dev:web": "cd web && npm run dev",
    "dev:landing": "cd landing && npm run dev",
    "dev:server": "uvicorn backend.main:app --reload --reload-exclude '*/backends/*' --port 17493",
    "setup:dev": "node scripts/setup-dev-sidecar.js",
    "build": "./scripts/build-server.sh && cd tauri && npm run tauri build",
    "build:web": "cd web && npm run build",
    "build:landing": "cd landing && npm run build",
    "build:release": "./scripts/prepare-release.sh",
    "generate:api": "./scripts/generate-api.sh",
    "generate:keys": "cd tauri && npx tauri signer generate -w ~/.tauri/voicebox.key",
    "build:server": "./scripts/build-server.sh",
    "update:icons": "./scripts/update-icons.sh",
    "convert:assets": "./scripts/convert-assets.sh",
    "lint": "biome lint .",
    "typecheck": "npx tsc -p app/tsconfig.json --noEmit && cd web && npx tsc --noEmit",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "npm run typecheck && npm run build:web"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@types/node": "^20.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "loaders.css": "^0.1.2",
    "react-loaders": "^3.0.1"
  }
}
